def Fraunhofferdiff(z, wavelength, sigma, minpos, maxpos, stepspos):
    image=numpy.zeros(steps,complex)
    imageplane=numpy.zeros(steps,complex)
    objectplane=numpy.zeros(steps,complex)
    m=0

    for rho in numpy.arange(minpos,maxpos,stepspos):
        object=0
        imageplane[m]=rho
        h=0
        for rhodash in numpy.arange(minpos,maxpos,stepspos):
            object+=A(rhodash, sigma)*U(rho, rhodash, wavelength, z)
            objectplane[h]=A(rhodash,sigma)
            h+=1
        image[m]=2.0*numpy.pi*object 
        m+=1 
    return image, imageplane, objectplane
    
 
