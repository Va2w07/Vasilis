def J_0(p):    
    theta=numpy.pi*(1.0 + xi)
    J_0int=sum(wi*numpy.exp(1.0J*p*numpy.cos(theta)))
    return J_0int/(2.0*numpy.pi)

def U(rho,rhodash,wavelength,z):
    p=((2.0*numpy.pi*rhodash*rho)/(wavelength*z))
    return J_0(p)*rhodash      

def A(rhodash, sigma):    
    return numpy.exp(-(rhodash/sigma)**2) 
    
