def L(u,v):
    if u<v:
        N=2*int(0.5*(20 + numpy.abs(v) + numpy.sqrt(30*numpy.abs(v)).real))
        even=True
        sumeven=0.0; sumodd=0.0
        An=1e-10; Anplus1=0.0; Anplus2=0.0
        a=(1.0J)*u/v
        for n in numpy.arange(N, -1, -1):
            Anminus1=((2*n+2)/v - a)*An + ((2*n+2)*a/v - 1.0)*Anplus1 - a*Anplus2
            if even: sumeven+=An
            else:    sumodd+=An
            even = not even
            (An, Anplus1, Anplus2) = (Anminus1, An, Anplus1)
        return Anplus1*numpy.exp((0.5J)*u)/(v*(-a*Anplus1 + Anminus1 + 2.0*(a*sumeven + sumodd)))
    else:
        N=2*int(0.5*(20 + numpy.abs(v) + numpy.sqrt(30*numpy.abs(v)).real))
        even=True
        sumeven=0.0; sumodd=0.0
        Bn=1e-10; Bnplus1=0.0; Bnplus2=0.0
        b=v/((1J)*u)
        for n in range(N, 0, -1):
            Bnminus1=(2*n/v + b)*Bn - (2*n*b/v + 1)*Bnplus1 + b*Bnplus2
            if even: sumeven+=Bn
            else:    sumodd+=Bn
            even = not even
            (Bn, Bnplus1, Bnplus2) = (Bnminus1, Bn, Bnplus1)
        return ((1J)/u)*numpy.exp((-0.5J)*v*v/u) - \
               Bnminus1*numpy.exp((0.5J)*u)/((1J*u)*(-Bn-b*Bnplus1 + \
               2.0*(-sumeven+b*sumodd)))

