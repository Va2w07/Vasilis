def savedatafile(y, filename, deltaf,M):
    fileobj=open(filename, 'w')
    for i in range(0,M):
        fileobj.write(str(i*deltaf*1e12)+","+str(y[i])+"\n")
    fileobj.close() 



def capitalj(n,x):
    even=True
    if (x==0.0) and (n==0): return 1.0
    if (x==0.0) and (n> 0): return 0.0
    nn=2*floor(.5*(abs(x)+n+20.0))
    a=0.0; b=1.0E-30; y=0.0; z=1.0
    i=nn
    while i>=0:
        if i==n: z=b
        c=2.0*i*b/x-a; a=b; b=c;
        if abs(c)>1.0e10: a*=1.0e-20; b*=1.0e-20; y*=1.0e-20; z*=1.0e-20
        if even>0: y=y+a
        even= not even
        i-=1
    
    y=y+y-a
    return z/y

def gaussint(a, b, delta, f):
    "Integrates f(x) between a and b with accuracy delta"
    n=8
    f1=I(n, a, b, f)
    f2=-f1
    while numpy.abs(f2-f1) > delta*numpy.abs(f1):
        if (n==16384):
            print "Can't achieve accuracy requested"
            return 0

        f2=f1
        n=2*n
        f1=I(n, a, b, f)

    return f1

